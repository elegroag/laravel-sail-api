<form id="confirmPasswordForm" class="needs-validation" novalidate>
    <div class="mb-4">
        <label class="form-label fw-bold text-center d-block">
            <i class="fas fa-key me-1"></i>
            Clave de Firma Digital
        </label>
        <div class="d-flex justify-content-center gap-2 mb-3">
            <% for (let i = 0; i < 6; i++) { %>
            <div class="digit-input-wrapper">
                <input 
                    type="text" 
                    class="form-control form-control-lg text-center digit-input" 
                    id="digit<%= i %>" 
                    name="digit<%= i %>"
                    maxlength="1"
                    pattern="[0-9]"
                    inputmode="numeric"
                    autocomplete="off"
                    required
                    data-index="<%= i %>"
                >
            </div>
            <% } %>
        </div>
        <input 
            type="hidden" 
            id="passwordInput" 
            name="password"
            required
        >
        <div class="invalid-feedback text-center">
            La clave de Firma Digital es requerida
        </div>
        <div class="form-text text-center">
            <small class="text-muted">
                <i class="fas fa-shield-alt me-1"></i>
                Ingrese los 6 dígitos de su clave de Firma Digital
            </small>
        </div>
    </div>
</form>

<div class="alert alert-info d-flex align-items-center" role="alert" style="background-color: #e3f2fd; border-color: #bbdefb; color: #1565c0;">
    <i class="fas fa-info-circle me-2"></i>
    <div>
        <%= message %>
    </div>
</div>

<style>
.digit-input-wrapper {
    width: 50px;
}

.digit-input {
    width: 100%;
    height: 60px;
    font-size: 24px;
    font-weight: bold;
    text-align: center;
    border: 2px solid #dee2e6;
    border-radius: 8px;
    transition: all 0.2s ease;
}

.digit-input:focus {
    border-color: #64b5f6;
    box-shadow: 0 0 0 0.25rem rgba(100, 181, 246, 0.25);
    transform: scale(1.05);
}

.digit-input.is-invalid {
    border-color: #ef9a9a;
    background-color: #ffebee;
}

.digit-input.is-valid {
    border-color: #a5d6a7;
    background-color: #e8f5e8;
}

@media (max-width: 576px) {
    .digit-input-wrapper {
        width: 40px;
    }
    
    .digit-input {
        height: 50px;
        font-size: 20px;
    }
}
</style>